    "hero": "linear-gradient(180deg, #fffdf8 0%, #faf8f2 70%, #f5efe4 100%) plus dark command-center visual",
    "game": "linear-gradient(180deg, #080e24 0%, #1b2d73 100%) with grid/scanline overlay",
    "proof": "linear-gradient(180deg, #fffdf8 0%, #f6f2e9 100%)",
