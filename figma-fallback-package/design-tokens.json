{
  "sourceFiles": [
    "tailwind.config.ts",
    "src/styles/index.css"
  ],
  "colors": {
    "navy": "#1B2D73",
    "navyAccent": "#273A86",
    "navyNight": "#080E24",
    "cream": "#FAF8F2",
